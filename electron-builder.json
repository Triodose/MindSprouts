{
  "appId": "com.triodose.mindsprouts",
  "productName": "MindSprouts",
  "directories": {
    "output": "dist-desktop"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "package.json"
  ],
  "win": {
    "target": "nsis"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  },
  "asar": true
}
